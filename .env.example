# Copy to .env and fill in your own values. Never commit a real .env file.

# --- PostgreSQL ---
# Async SQLAlchemy connection string used by the application and Alembic.
DB_URL=postgresql+asyncpg://arbitrage:arbitrage@localhost:5432/arbitrage

# Credentials consumed by docker-compose for the bundled Postgres container.
POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=change_me
POSTGRES_DB=arbitrage

# --- Redis ---
REDIS_URL=redis://localhost:6379/

# --- Scanner ---
# Minimum cross-exchange spread (percent) worth persisting as an opportunity.
SPREAD_THRESHOLD=0.5

# Verbose SQL / debug logging.
DEBUG=false

# --- Exchange API keys (optional) ---
# Public market-data streams need NO credentials. These are placeholders only,
# provided for anyone extending the project with authenticated endpoints.
# Do NOT use live trading keys in a demo environment.
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=
